# Example override file for local adjustments.
# Copy this to docker-compose/override.env and change values as needed.
# This file should NOT be committed; use override.env locally and it's ignored by git.

# Host and network
HOST_IP=127.0.0.1

# Postgres (external port for host access)
# SECURITY: always bind to 127.0.0.1, never to 0.0.0.0.
# Using 0.0.0.0 exposes PostgreSQL to the public internet and bypasses any
# host firewall (Docker inserts its own iptables rules before UFW/iptables INPUT).
# A publicly reachable PostgreSQL port allows attackers to brute-force credentials
# and exploit superuser features (e.g. COPY FROM PROGRAM) to execute arbitrary
# commands inside the container, leading to full container compromise.
POSTGRES_EXTERNAL_PORT=127.0.0.1:5432
POSTGRES_PASSWORD=postgres
